{
  "name": "plakar.io",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:hugo": "hugo server",
    "dev:tailwind": "NODE_ENV=development ./themes/blowfish/node_modules/@tailwindcss/cli/dist/index.mjs -c ./themes/blowfish/tailwind.config.js -i ./themes/blowfish/assets/css/main.css -o ./assets/css/compiled/main.css --jit -w",
    "build": "npm-run-all build:*",
    "build:hugo": "hugo",
    "build:tailwind": "NODE_ENV=production ./themes/blowfish/node_modules/@tailwindcss/cli/dist/index.mjs -c ./themes/blowfish/tailwind.config.js -i ./themes/blowfish/assets/css/main.css -o ./assets/css/compiled/main.css --jit",
    "build:pagefind": "npx -y pagefind --site public"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
